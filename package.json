{
  "name": "stock-ticker-stream-deck-plugin",
  "private": true,
  "version": "2.0.1",
  "description": "Official Stream Deck SDK implementation of the stock ticker plugin.",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "validate": "streamdeck validate --no-update-check ./com.exension.stocks.v2.sdPlugin",
    "link": "streamdeck link ./com.exension.stocks.v2.sdPlugin",
    "pack": "streamdeck pack --no-update-check ./com.exension.stocks.v2.sdPlugin -o ./release -f"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.9.1",
    "rollup": "^4.41.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
